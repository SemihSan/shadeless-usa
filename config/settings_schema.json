  {
    "name": "Typography",
    "settings": [
      {
        "type": "header",
        "content": "Font settings"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body font",
        "default": "assistant_n4"
      },
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading font",
        "default": "assistant_n7"
      },
      {
        "type": "font_picker",
        "id": "font_logo",
        "label": "Logo font",
        "default": "playfair_display_n4",
        "info": "Used for the text logo in the header."
      },
      {
        "type": "range",
        "id": "font_size_base",
        "label": "Base font size",
        "min": 14,
        "max": 20,
        "step": 1,
        "unit": "px",
        "default": 16
      }
    ]
  },
  {
    "name": "Logo & Brand",
    "settings": [
      {
        "type": "header",
        "content": "Logo"
      },
      {
        "type": "image_picker",
        "id": "logo_image",
        "label": "Logo image",
        "info": "If empty, the text logo will be shown. Recommended max height: 60px."
      },
      {
        "type": "range",
        "id": "logo_max_width",
        "label": "Logo max width",
        "min": 80,
        "max": 300,
        "step": 10,
        "unit": "px",
        "default": 160
      },
      {
        "type": "text",
        "id": "logo_text",
        "label": "Text logo",
        "default": "SHADELESS",
        "info": "Shown when no logo image is uploaded."
      },
      {
        "type": "header",
        "content": "Brand info"
      },
      {
        "type": "text",
        "id": "brand_name",
        "label": "Brand name",
        "default": "Shadeless"
      },
      {
        "type": "textarea",
        "id": "brand_tagline",
        "label": "Brand tagline",
        "default": "Biotech skincare for more even-looking tone, smoother texture, and cleaner skin clarity."
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
        "info": "Appears in browser tabs. Use a square PNG, at least 32x32px."
      }
    ]
  },
