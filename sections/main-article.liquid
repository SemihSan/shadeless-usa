<section class="page-hero">
  <div class="sh-container">
    <div class="sh-eyebrow">{{ article.published_at | date: '%b %d, %Y' }}</div>
    <h1 class="sh-h1">{{ article.title }}</h1>
    {% if article.author %}<p class="sh-small">By {{ article.author }}</p>{% endif %}
  </div>
</section>
<section class="sh-section">
  <div class="sh-container" style="max-width:820px;">
    {% if article.image %}
      {{ article.image | image_url: width: 1400 | image_tag: loading: 'eager', alt: article.title }}
    {% endif %}
    <div class="sh-body" style="margin-top:30px;">{{ article.content }}</div>

    {% if blog.comments_enabled? %}
      <div style="margin-top:40px;">
        <h2 class="sh-h2">Comments ({{ article.comments_count }})</h2>
        {% for comment in article.comments %}
          <div class="sh-card" style="margin-bottom:14px;">
            <strong>{{ comment.author }}</strong>
            <p class="sh-small">{{ comment.created_at | date: '%b %d, %Y' }}</p>
            <div>{{ comment.content }}</div>
          </div>
        {% endfor %}
        {% form 'new_comment', article, class: 'contact-form' %}
          <input type="text" name="comment[author]" placeholder="Name" required>
          <input type="email" name="comment[email]" placeholder="Email" required>
          <textarea name="comment[body]" rows="5" placeholder="Comment" required></textarea>
          <button class="sh-button sh-button--red" type="submit">Post Comment</button>
          {% if form.posted_successfully? %}<div class="newsletter-success">Thank you. Your comment has been posted.</div>{% endif %}
          {% if form.errors %}<div class="sh-small">{{ form.errors | default_errors }}</div>{% endif %}
        {% endform %}
      </div>
    {% endif %}
  </div>
</section>
{% schema %}
{"name":"Main article","settings":[]}
{% endschema %}
