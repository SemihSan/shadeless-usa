<section class="page-hero"><div class="sh-container"><h1 class="sh-h1">Cart</h1></div></section>
<section class="sh-section"><div class="sh-container">{% if cart.item_count > 0 %}<form action="{{ routes.cart_url }}" method="post"><table class="cart-table"><thead><tr><th>Product</th><th>Quantity</th><th>Total</th></tr></thead><tbody>{% for item in cart.items %}<tr><td><a href="{{ item.url }}">{{ item.product.title }}</a><br><span class="sh-small">{{ item.variant.title }}</span></td><td><input class="quantity-input" type="number" name="updates[]" value="{{ item.quantity }}" min="0"></td><td>{{ item.final_line_price | money }}</td></tr>{% endfor %}</tbody></table><div class="cart-actions"><strong>Subtotal: {{ cart.total_price | money }}</strong><button class="sh-button sh-button--secondary" type="submit">Update Cart</button><button class="sh-button sh-button--red" name="checkout" type="submit">Checkout</button></div></form>{% else %}<div class="sh-center"><p class="sh-body">Your cart is currently empty.</p><a class="sh-button" href="{{ routes.all_products_collection_url }}">Shop Shadeless</a></div>{% endif %}</div></section>
{% schema %}
{"name":"Main cart","settings":[]}
{% endschema %}
