<div class="announcement" {% if section.settings.link != blank %}style="cursor:pointer;" onclick="window.location='{{ section.settings.link }}'"{% endif %}>
  {% if section.settings.show_emoji %}<span>{{ section.settings.emoji }}</span> {% endif %}
  {{ section.settings.text }}
  {% if section.settings.link != blank and section.settings.link_label != blank %} — <a href="{{ section.settings.link }}" style="color:inherit;text-decoration:underline;font-weight:700;">{{ section.settings.link_label }}</a>{% endif %}
</div>
{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Announcement text",
      "default": "Introducing the Shadeless 3-Step Serum System — Prepare. Optimize. Enhance."
    },
    {
      "type": "checkbox",
      "id": "show_emoji",
      "label": "Show emoji/icon",
      "default": false
    },
    {
      "type": "text",
      "id": "emoji",
      "label": "Emoji or symbol",
      "default": "✨",
      "info": "Only shown if 'Show emoji' is checked."
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optional)",
      "info": "Makes the entire bar clickable."
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label (optional)",
      "default": "Shop Now",
      "info": "Shows as a clickable underlined label at the end of the text."
    }
  ]
}
{% endschema %}
