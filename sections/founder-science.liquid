<section class="sh-section"
  style="{% if section.settings.custom_bg != blank %}background:{{ section.settings.custom_bg }};{% elsif section.settings.bg_style == 'soft' %}background:linear-gradient(180deg,#fff,var(--soft));{% endif %}{% if section.settings.padding_top > 0 %}padding-top:{{ section.settings.padding_top }}px;{% endif %}{% if section.settings.padding_bottom > 0 %}padding-bottom:{{ section.settings.padding_bottom }}px;{% endif %}">
  <div class="sh-container sh-center">
    {% if section.settings.image %}
      <div style="width:{{ section.settings.image_size }}px;height:{{ section.settings.image_size }}px;border-radius:50%;overflow:hidden;margin:0 auto 24px;box-shadow:var(--shadow);">
        {{ section.settings.image | image_url: width: 400 | image_tag: loading: 'lazy', alt: section.settings.heading }}
      </div>
    {% endif %}
    {% if section.settings.eyebrow != blank %}<div class="sh-eyebrow">{{ section.settings.eyebrow }}</div>{% endif %}
    <h2 class="sh-h2">{{ section.settings.heading }}</h2>
    {% if section.settings.body != blank %}<p class="sh-body" style="max-width:850px;margin:0 auto;">{{ section.settings.body }}</p>{% endif %}
    {% if section.settings.cta_label != blank %}
      <div style="margin-top:26px;">
        <a class="sh-button" href="{{ section.settings.cta_link | default: '/pages/our-story' }}">{{ section.settings.cta_label }}</a>
      </div>
    {% endif %}
  </div>
</section>
{% schema %}
{
  "name": "Founder / brand module",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Portrait / image",
      "info": "Displayed as a circle above the heading."
    },
    {
      "type": "range",
      "id": "image_size",
      "label": "Image size",
      "min": 80,
      "max": 280,
      "step": 10,
      "unit": "px",
      "default": 160
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Brand foundation"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Built from a biotechnology mindset. Designed as a daily routine."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Shadeless was developed to translate sophisticated formulation thinking into a routine that is simple enough to use every day."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Read Our Story"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Section appearance"
    },
    {
      "type": "select",
      "id": "bg_style",
      "label": "Background style",
      "options": [
        {"value": "white", "label": "White"},
        {"value": "soft", "label": "Soft gradient"},
        {"value": "custom", "label": "Custom color"}
      ],
      "default": "soft"
    },
    {
      "type": "color",
      "id": "custom_bg",
      "label": "Custom background color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0, "max": 160, "step": 4, "unit": "px", "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0, "max": 160, "step": 4, "unit": "px", "default": 0
    }
  ],
  "presets": [{"name": "Founder / brand module"}]
}
{% endschema %}
