<section class="sh-section">
  <div class="sh-container sh-center">
    <div class="sh-eyebrow">{{ section.settings.eyebrow }}</div>
    <h2 class="sh-h2">{{ section.settings.heading }}</h2>
    <p class="sh-body" style="max-width:820px;margin:0 auto;">{{ section.settings.body }}</p>
    <div class="sh-grid sh-grid-3" style="margin-top:34px;text-align:left;">
      <div class="sh-card"><h3 class="sh-h3">{{ section.settings.card1_title }}</h3><p>{{ section.settings.card1_body }}</p></div>
      <div class="sh-card"><h3 class="sh-h3">{{ section.settings.card2_title }}</h3><p>{{ section.settings.card2_body }}</p></div>
      <div class="sh-card"><h3 class="sh-h3">{{ section.settings.card3_title }}</h3><p>{{ section.settings.card3_body }}</p></div>
    </div>
    <p class="sh-small" style="margin-top:22px;">{{ section.settings.disclaimer }}</p>
  </div>
</section>
{% schema %}
{
  "name": "Proof placeholder",
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Results"},
    {"type": "textarea", "id": "heading", "label": "Heading", "default": "Visible results should be documented, not exaggerated."},
    {"type": "textarea", "id": "body", "label": "Body text", "default": "We are building our U.S. results library through verified customer reviews, product feedback, and future consumer perception studies."},
    {"type": "header", "content": "Card 1"},
    {"type": "text", "id": "card1_title", "label": "Title", "default": "Verified customer reviews"},
    {"type": "textarea", "id": "card1_body", "label": "Body", "default": "Coming soon."},
    {"type": "header", "content": "Card 2"},
    {"type": "text", "id": "card2_title", "label": "Title", "default": "Consumer perception study"},
    {"type": "textarea", "id": "card2_body", "label": "Body", "default": "Coming soon."},
    {"type": "header", "content": "Card 3"},
    {"type": "text", "id": "card3_title", "label": "Title", "default": "Before / after policy"},
    {"type": "textarea", "id": "card3_body", "label": "Body", "default": "Consent, consistent lighting, and clear usage context."},
    {"type": "text", "id": "disclaimer", "label": "Disclaimer text", "default": "Individual results may vary."}
  ],
  "presets": [{"name": "Proof placeholder"}]
}
{% endschema %}
