<section class="page-hero"><div class="sh-container"><div class="sh-eyebrow">Contact</div><h1 class="sh-h1">Contact Shadeless</h1><p class="sh-body">Questions about your order, routine, product information, or partnership opportunities? Send us a note.</p></div></section>
<section class="sh-section"><div class="sh-container">{% form 'contact', class: 'contact-form' %}<input type="text" name="contact[name]" placeholder="Name"><input type="email" name="contact[email]" placeholder="Email" required><select name="contact[inquiry_type]"><option>Order support</option><option>Product question</option><option>Routine guidance</option><option>Press</option><option>Retail partnership</option><option>Professional / esthetician inquiry</option><option>Other</option></select><textarea name="contact[body]" rows="6" placeholder="Message"></textarea><button class="sh-button sh-button--red" type="submit">Send Message</button>{% if form.posted_successfully? %}<div class="newsletter-success">Thank you. We received your message.</div>{% endif %}{% if form.errors %}{{ form.errors | default_errors }}{% endif %}{% endform %}<div class="sh-center" style="margin-top:40px;"><p class="sh-body">Shadeless Biotechnology Inc.<br>265 Franklin Street Ste 1702<br>Boston, MA 02110</p></div></div></section>
{% schema %}
{"name":"Page - Contact","settings":[]}
{% endschema %}
