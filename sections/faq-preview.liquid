<section class="sh-section"
  style="{% if section.settings.custom_bg != blank %}background:{{ section.settings.custom_bg }};{% elsif section.settings.bg_style == 'soft' %}background:linear-gradient(180deg,#fff,var(--soft));{% endif %}{% if section.settings.padding_top > 0 %}padding-top:{{ section.settings.padding_top }}px;{% endif %}{% if section.settings.padding_bottom > 0 %}padding-bottom:{{ section.settings.padding_bottom }}px;{% endif %}">
  <div class="sh-container">
    <div class="sh-center">
      {% if section.settings.eyebrow != blank %}<div class="sh-eyebrow">{{ section.settings.eyebrow }}</div>{% endif %}
      <h2 class="sh-h2">{{ section.settings.heading }}</h2>
    </div>
    <div class="accordion" style="max-width:880px;margin:30px auto 0;">
      {% for block in section.blocks %}
        <details {{ block.shopify_attributes }}>
          <summary>{{ block.settings.question }}</summary>
          <div class="content">{{ block.settings.answer }}</div>
        </details>
      {% endfor %}
    </div>
    {% if section.settings.cta_label != blank %}
      <div class="sh-center" style="margin-top:30px;">
        <a class="sh-button sh-button--secondary" href="{{ section.settings.cta_link | default: '/pages/faq' }}">{{ section.settings.cta_label }}</a>
      </div>
    {% endif %}
  </div>
</section>
{% schema %}
{
  "name": "FAQ preview",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "FAQ"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Before you start the system"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Read the FAQ"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Section appearance"
    },
    {
      "type": "select",
      "id": "bg_style",
      "label": "Background style",
      "options": [
        {"value": "white", "label": "White"},
        {"value": "soft", "label": "Soft gradient"},
        {"value": "custom", "label": "Custom color"}
      ],
      "default": "soft"
    },
    {
      "type": "color",
      "id": "custom_bg",
      "label": "Custom background color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0, "max": 160, "step": 4, "unit": "px", "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0, "max": 160, "step": 4, "unit": "px", "default": 0
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How do I use the 3-step system?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Apply Step 1, then Step 2, then Step 3. Finish with sunscreen in the morning."
        }
      ]
    }
  ],
  "presets": [{"name": "FAQ preview"}]
}
{% endschema %}
