<section class="sh-section sh-bleed">
  <div class="sh-container">
    <div class="sh-center"><div class="sh-eyebrow">{{ section.settings.eyebrow }}</div><h2 class="sh-h2">{{ section.settings.heading }}</h2></div>
    <div class="accordion" style="max-width:880px;margin:30px auto 0;">
      {% for block in section.blocks %}
        <details {{ block.shopify_attributes }}>
          <summary>{{ block.settings.question }}</summary>
          <div class="content">{{ block.settings.answer }}</div>
        </details>
      {% endfor %}
    </div>
    <div class="sh-center" style="margin-top:30px;"><a class="sh-button sh-button--secondary" href="{{ section.settings.cta_link | default: '/pages/faq' }}">{{ section.settings.cta_label }}</a></div>
  </div>
</section>
{% schema %}
{
  "name": "FAQ preview",
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "FAQ"},
    {"type": "textarea", "id": "heading", "label": "Heading", "default": "Before you start the system"},
    {"type": "text", "id": "cta_label", "label": "Button label", "default": "Read the FAQ"},
    {"type": "url", "id": "cta_link", "label": "Button link"}
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        {"type": "text", "id": "question", "label": "Question"},
        {"type": "textarea", "id": "answer", "label": "Answer"}
      ]
    }
  ],
  "presets": [{"name": "FAQ preview"}]
}
{% endschema %}
