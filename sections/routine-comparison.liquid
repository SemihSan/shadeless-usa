<section class="sh-section"
  style="{% if section.settings.custom_bg != blank %}background:{{ section.settings.custom_bg }};{% elsif section.settings.bg_style == 'soft' %}background:linear-gradient(180deg,#fff,var(--soft));{% endif %}{% if section.settings.padding_top > 0 %}padding-top:{{ section.settings.padding_top }}px;{% endif %}{% if section.settings.padding_bottom > 0 %}padding-bottom:{{ section.settings.padding_bottom }}px;{% endif %}">
  <div class="sh-container">
    <div class="sh-center">
      {% if section.settings.eyebrow != blank %}<div class="sh-eyebrow">{{ section.settings.eyebrow }}</div>{% endif %}
      <h2 class="sh-h2">{{ section.settings.heading }}</h2>
      {% if section.settings.body != blank %}<p class="sh-body" style="max-width:820px;margin:0 auto;">{{ section.settings.body }}</p>{% endif %}
    </div>
    <div class="comparison" style="margin-top:34px;">
      <div class="comparison-card bad">
        {% if section.settings.bad_title != blank %}<h3 class="sh-h3">{{ section.settings.bad_title }}</h3>{% endif %}
        <ul class="sh-list">
          {% for block in section.blocks %}
            {% if block.type == 'bad_item' %}
              <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>
      <div class="comparison-card good">
        {% if section.settings.good_title != blank %}<h3 class="sh-h3">{{ section.settings.good_title }}</h3>{% endif %}
        <ul class="sh-list">
          {% for block in section.blocks %}
            {% if block.type == 'good_item' %}
              <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>
    </div>
    {% if section.settings.quote != blank %}<div class="quote-band">{{ section.settings.quote }}</div>{% endif %}
  </div>
</section>
{% schema %}
{
  "name": "Routine comparison",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "System logic"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "When the concern is complex, the routine should be coordinated."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Many skincare routines are built by stacking products. But stacking is not the same as sequencing."
    },
    {
      "type": "text",
      "id": "bad_title",
      "label": "Left column title",
      "default": "Random stacking"
    },
    {
      "type": "text",
      "id": "good_title",
      "label": "Right column title",
      "default": "Shadeless sequence"
    },
    {
      "type": "text",
      "id": "quote",
      "label": "Quote band text",
      "default": "Most routines stack. Shadeless sequences."
    },
    {
      "type": "header",
      "content": "Section appearance"
    },
    {
      "type": "select",
      "id": "bg_style",
      "label": "Background style",
      "options": [
        {"value": "white", "label": "White"},
        {"value": "soft", "label": "Soft gradient"},
        {"value": "custom", "label": "Custom color"}
      ],
      "default": "soft"
    },
    {
      "type": "color",
      "id": "custom_bg",
      "label": "Custom background color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0, "max": 160, "step": 4, "unit": "px", "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0, "max": 160, "step": 4, "unit": "px", "default": 0
    }
  ],
  "blocks": [
    {
      "type": "bad_item",
      "name": "Left column item",
      "settings": [
        {"type": "text", "id": "text", "label": "Item text", "default": "One serum for glow"}
      ]
    },
    {
      "type": "good_item",
      "name": "Right column item",
      "settings": [
        {"type": "text", "id": "text", "label": "Item text", "default": "Step 1 prepares"}
      ]
    }
  ],
  "presets": [
    {
      "name": "Routine comparison",
      "blocks": [
        {"type": "bad_item", "settings": {"text": "One serum for glow"}},
        {"type": "bad_item", "settings": {"text": "One serum for pores"}},
        {"type": "bad_item", "settings": {"text": "One serum for texture"}},
        {"type": "bad_item", "settings": {"text": "One serum for comfort"}},
        {"type": "bad_item", "settings": {"text": "No clear sequence"}},
        {"type": "good_item", "settings": {"text": "Step 1 prepares"}},
        {"type": "good_item", "settings": {"text": "Step 2 optimizes"}},
        {"type": "good_item", "settings": {"text": "Step 3 enhances"}},
        {"type": "good_item", "settings": {"text": "One clear system"}},
        {"type": "good_item", "settings": {"text": "Routine logic built in"}}
      ]
    }
  ]
}
{% endschema %}
