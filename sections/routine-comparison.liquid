<section class="sh-section sh-bleed">
  <div class="sh-container product-feature">
    <div class="product-feature-image">
      {% assign featured_product = all_products[section.settings.product] %}
      {% if featured_product and featured_product.featured_image %}
        {{ featured_product.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: featured_product.title }}
      {% else %}
        <img src="{{ 'shadeless-front.png' | asset_url }}" alt="Shadeless 3-Step Serum System">
      {% endif %}
    </div>
    <div>
      <div class="sh-eyebrow">{{ section.settings.eyebrow }}</div>
      <h2 class="sh-h2">{{ section.settings.heading }}</h2>
      <p class="sh-body">{{ section.settings.body }}</p>
      <ul class="sh-list">
        {% assign list_items = section.settings.list_items | newline_to_br | split: '<br />' %}
        {% for item in list_items %}{% assign item_clean = item | strip %}{% if item_clean != '' %}<li>{{ item_clean }}</li>{% endif %}{% endfor %}
      </ul>
      <div class="sh-button-row" style="margin-top:24px;">
        <a class="sh-button sh-button--red" href="{% if featured_product %}{{ featured_product.url }}{% else %}{{ section.settings.primary_link | default: '/products/shadeless-3-step-serum-system' }}{% endif %}">{{ section.settings.primary_label }}</a>
        <a class="sh-button sh-button--secondary" href="{{ section.settings.secondary_link | default: '/pages/the-3-step-system' }}">{{ section.settings.secondary_label }}</a>
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Featured 3-Step System",
  "settings": [
    {"type": "product", "id": "product", "label": "Featured product"},
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Best place to start"},
    {"type": "textarea", "id": "heading", "label": "Heading", "default": "Start with the full 3-Step Serum System."},
    {"type": "textarea", "id": "body", "label": "Body text", "default": "A biotech serum system for more even-looking tone, smoother-looking texture, and cleaner skin clarity."},
    {"type": "textarea", "id": "list_items", "label": "List items (one per line)", "default": "Step 1 Prepare Serum\nStep 2 Optimize Serum\nStep 3 Enhance Serum\nRoutine Guide"},
    {"type": "text", "id": "primary_label", "label": "Primary button label", "default": "Shop the System"},
    {"type": "url", "id": "primary_link", "label": "Primary button link (if no product selected)"},
    {"type": "text", "id": "secondary_label", "label": "Secondary button label", "default": "Compare the Steps"},
    {"type": "url", "id": "secondary_link", "label": "Secondary button link"}
  ],
  "presets": [{"name": "Featured 3-Step System"}]
}
{% endschema %}
