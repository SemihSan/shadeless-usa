<section class="sh-section">
  <div class="sh-container sh-center">
    <div class="sh-eyebrow">{{ section.settings.eyebrow }}</div>
    <h2 class="sh-h2">{{ section.settings.heading }}</h2>
    <p class="sh-body" style="max-width:720px;margin:0 auto;">{{ section.settings.body }}</p>
    {% form 'customer', class: 'email-form' %}
      <input type="hidden" name="contact[tags]" value="routine-guide">
      <input type="email" name="contact[email]" required placeholder="{{ section.settings.placeholder }}" aria-label="Email">
      <button class="sh-button sh-button--red" type="submit">{{ section.settings.button_label }}</button>
      {% if form.posted_successfully? %}<div class="newsletter-success">{{ section.settings.success_message }}</div>{% endif %}
      {% if form.errors %}<div class="sh-small">{{ form.errors | default_errors }}</div>{% endif %}
    {% endform %}
    <p class="sh-small">{{ section.settings.legal_text }}</p>
  </div>
</section>
{% schema %}
{
  "name": "Email capture",
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Routine guide"},
    {"type": "textarea", "id": "heading", "label": "Heading", "default": "Get the Shadeless Routine Guide"},
    {"type": "textarea", "id": "body", "label": "Body text", "default": "Learn how to use the 3-Step Serum System for more even-looking tone, smoother-looking texture, and cleaner skin clarity."},
    {"type": "text", "id": "placeholder", "label": "Email placeholder", "default": "Enter your email"},
    {"type": "text", "id": "button_label", "label": "Button label", "default": "Send Me the Guide"},
    {"type": "text", "id": "success_message", "label": "Success message", "default": "Thank you. Your guide request has been received."},
    {"type": "text", "id": "legal_text", "label": "Legal text", "default": "By signing up, you agree to receive emails from Shadeless. You can unsubscribe at any time."}
  ],
  "presets": [{"name": "Email capture"}]
}
{% endschema %}
