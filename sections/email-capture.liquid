<section class="sh-section">
  <div class="sh-container sh-center">
    <div class="sh-eyebrow">Routine guide</div>
    <h2 class="sh-h2">Get the Shadeless Routine Guide</h2>
    <p class="sh-body" style="max-width:720px;margin:0 auto;">Learn how to use the 3-Step Serum System for more even-looking tone, smoother-looking texture, and cleaner skin clarity.</p>
    {% form 'customer', class: 'email-form' %}
      <input type="hidden" name="contact[tags]" value="routine-guide">
      <input type="email" name="contact[email]" required placeholder="Enter your email" aria-label="Email">
      <button class="sh-button sh-button--red" type="submit">Send Me the Guide</button>
      {% if form.posted_successfully? %}<div class="newsletter-success">Thank you. Your guide request has been received.</div>{% endif %}
      {% if form.errors %}<div class="sh-small">{{ form.errors | default_errors }}</div>{% endif %}
    {% endform %}
    <p class="sh-small">By signing up, you agree to receive emails from Shadeless. You can unsubscribe at any time.</p>
  </div>
</section>
{% schema %}
{
  "name": "Email capture Routine Guide",
  "settings": [],
  "presets": [{"name": "Email capture Routine Guide"}]
}
{% endschema %}
