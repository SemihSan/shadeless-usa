<section class="sh-section"
  style="{% if section.settings.custom_bg != blank %}background:{{ section.settings.custom_bg }};{% elsif section.settings.bg_style == 'soft' %}background:linear-gradient(180deg,#fff,var(--soft));{% elsif section.settings.bg_style == 'dark' %}background:var(--black);color:#fff;{% elsif section.settings.bg_style == 'accent' %}background:var(--red);color:#fff;{% endif %}{% if section.settings.padding_top > 0 %}padding-top:{{ section.settings.padding_top }}px;{% endif %}{% if section.settings.padding_bottom > 0 %}padding-bottom:{{ section.settings.padding_bottom }}px;{% endif %}">
  {% if section.settings.bg_image %}
    <div style="position:relative;overflow:hidden;">
      <div style="position:absolute;inset:0;background-image:url('{{ section.settings.bg_image | image_url: width: 1800 }}');background-size:cover;background-position:center;opacity:{{ section.settings.bg_image_opacity | divided_by: 100.0 }};"></div>
      <div style="position:relative;z-index:1;" class="sh-container sh-center">
  {% else %}
  <div class="sh-container sh-center">
  {% endif %}
    {% if section.settings.eyebrow != blank %}<div class="sh-eyebrow" style="{% if section.settings.bg_style == 'dark' or section.settings.bg_style == 'accent' %}color:rgba(255,255,255,.7);{% endif %}">{{ section.settings.eyebrow }}</div>{% endif %}
    <h2 class="sh-h2">{{ section.settings.heading }}</h2>
    {% if section.settings.body != blank %}<p class="sh-body" style="max-width:740px;margin:0 auto 28px;">{{ section.settings.body }}</p>{% endif %}
    {% if section.settings.cta_label != blank %}
      <a class="sh-button sh-button--red" href="{{ section.settings.cta_link | default: '/products/shadeless-3-step-serum-system' }}">{{ section.settings.cta_label }}</a>
    {% endif %}
    {% if section.settings.secondary_label != blank %}
      <a class="sh-button sh-button--secondary" href="{{ section.settings.secondary_link }}" style="{% if section.settings.bg_style == 'dark' %}color:#fff;border-color:rgba(255,255,255,.4);{% endif %}margin-left:12px;">{{ section.settings.secondary_label }}</a>
    {% endif %}
  </div>
  {% if section.settings.bg_image %}
    </div>
  {% endif %}
</section>
{% schema %}
{
  "name": "Final CTA",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Start the system"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Bring sequence to your skincare routine."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Prepare. Optimize. Enhance. Start the 3-step system designed for more even-looking tone, smoother-looking texture, and cleaner skin clarity."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Primary button label",
      "default": "Shop the 3-Step Serum System"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label (optional)"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "header",
      "content": "Section appearance"
    },
    {
      "type": "select",
      "id": "bg_style",
      "label": "Background style",
      "options": [
        {"value": "white", "label": "White"},
        {"value": "soft", "label": "Soft gradient"},
        {"value": "dark", "label": "Dark"},
        {"value": "accent", "label": "Accent / brand color"},
        {"value": "custom", "label": "Custom color"}
      ],
      "default": "soft"
    },
    {
      "type": "color",
      "id": "custom_bg",
      "label": "Custom background color"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image (optional)"
    },
    {
      "type": "range",
      "id": "bg_image_opacity",
      "label": "Background image opacity",
      "min": 5, "max": 100, "step": 5, "unit": "%", "default": 20
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0, "max": 160, "step": 4, "unit": "px", "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0, "max": 160, "step": 4, "unit": "px", "default": 0
    }
  ],
  "presets": [{"name": "Final CTA"}]
}
{% endschema %}
