<section class="sh-section sh-bleed">
  <div class="sh-container sh-center">
    <div class="sh-eyebrow">{{ section.settings.eyebrow }}</div>
    <h2 class="sh-h2">{{ section.settings.heading }}</h2>
    <p class="sh-body" style="max-width:740px;margin:0 auto 28px;">{{ section.settings.body }}</p>
    <a class="sh-button sh-button--red" href="{{ section.settings.cta_link | default: '/products/shadeless-3-step-serum-system' }}">{{ section.settings.cta_label }}</a>
  </div>
</section>
{% schema %}
{
  "name": "Final CTA",
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Start the system"},
    {"type": "textarea", "id": "heading", "label": "Heading", "default": "Bring sequence to your skincare routine."},
    {"type": "textarea", "id": "body", "label": "Body text", "default": "Prepare. Optimize. Enhance. Start the 3-step system designed for more even-looking tone, smoother-looking texture, and cleaner skin clarity."},
    {"type": "text", "id": "cta_label", "label": "Button label", "default": "Shop the 3-Step Serum System"},
    {"type": "url", "id": "cta_link", "label": "Button link"}
  ],
  "presets": [{"name": "Final CTA"}]
}
{% endschema %}
