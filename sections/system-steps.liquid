<section class="sh-section">
  <div class="sh-container">
    <div class="sh-center"><div class="sh-eyebrow">{{ section.settings.eyebrow }}</div><h2 class="sh-h2">{{ section.settings.heading }}</h2><p class="sh-body" style="max-width:820px;margin:0 auto;">{{ section.settings.body }}</p></div>
    <div class="sh-grid sh-grid-3" style="margin-top:42px;">
      <article class="sh-card step-card"><div class="step-number">Step 1</div><h3 class="sh-h3">{{ section.settings.step1_title }}</h3><p class="role">{{ section.settings.step1_role }}</p><p>{{ section.settings.step1_body }}</p><p class="sh-small"><strong>Best for:</strong> {{ section.settings.step1_best_for }}</p><a class="sh-button sh-button--secondary" href="{{ section.settings.step1_link | default: '/products/step-1-prepare-serum' }}">{{ section.settings.step1_label }}</a></article>
      <article class="sh-card step-card"><div class="step-number">Step 2</div><h3 class="sh-h3">{{ section.settings.step2_title }}</h3><p class="role">{{ section.settings.step2_role }}</p><p>{{ section.settings.step2_body }}</p><p class="sh-small"><strong>Best for:</strong> {{ section.settings.step2_best_for }}</p><a class="sh-button sh-button--secondary" href="{{ section.settings.step2_link | default: '/products/step-2-optimize-serum' }}">{{ section.settings.step2_label }}</a></article>
      <article class="sh-card step-card"><div class="step-number">Step 3</div><h3 class="sh-h3">{{ section.settings.step3_title }}</h3><p class="role">{{ section.settings.step3_role }}</p><p>{{ section.settings.step3_body }}</p><p class="sh-small"><strong>Best for:</strong> {{ section.settings.step3_best_for }}</p><a class="sh-button sh-button--secondary" href="{{ section.settings.step3_link | default: '/products/step-3-enhance-serum' }}">{{ section.settings.step3_label }}</a></article>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "System steps",
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Prepare. Optimize. Enhance."},
    {"type": "textarea", "id": "heading", "label": "Heading", "default": "Three steps. One visible skin-refinement system."},
    {"type": "textarea", "id": "body", "label": "Body text", "default": "Each serum has a defined role. Together, they create a complete routine for skin that looks smoother, clearer, more even, and more refined."},
    {"type": "header", "content": "Step 1"},
    {"type": "text", "id": "step1_title", "label": "Title", "default": "Prepare Serum"},
    {"type": "text", "id": "step1_role", "label": "Role", "default": "The surface-preparation step."},
    {"type": "textarea", "id": "step1_body", "label": "Description", "default": "Helps skin look fresher, smoother, and more ready for the next steps in the system."},
    {"type": "text", "id": "step1_best_for", "label": "Best for", "default": "rough-looking texture, dullness, lack of smoothness."},
    {"type": "text", "id": "step1_label", "label": "Button label", "default": "Learn Step 1"},
    {"type": "url", "id": "step1_link", "label": "Button link"},
    {"type": "header", "content": "Step 2"},
    {"type": "text", "id": "step2_title", "label": "Title", "default": "Optimize Serum"},
    {"type": "text", "id": "step2_role", "label": "Role", "default": "The core tone + texture step."},
    {"type": "textarea", "id": "step2_body", "label": "Description", "default": "Designed to support the appearance of more even-looking tone, smoother-looking texture, and clearer-looking skin."},
    {"type": "text", "id": "step2_best_for", "label": "Best for", "default": "uneven-looking tone, dullness, visible pores, post-blemish mark appearance."},
    {"type": "text", "id": "step2_label", "label": "Button label", "default": "Learn Step 2"},
    {"type": "url", "id": "step2_link", "label": "Button link"},
    {"type": "header", "content": "Step 3"},
    {"type": "text", "id": "step3_title", "label": "Title", "default": "Enhance Serum"},
    {"type": "text", "id": "step3_role", "label": "Role", "default": "The tone + texture completion step."},
    {"type": "textarea", "id": "step3_body", "label": "Description", "default": "Designed to enhance the final look of clarity, smoothness, polish, and refinement."},
    {"type": "text", "id": "step3_best_for", "label": "Best for", "default": "skin that needs a more finished, luminous, confident look."},
    {"type": "text", "id": "step3_label", "label": "Button label", "default": "Learn Step 3"},
    {"type": "url", "id": "step3_link", "label": "Button link"}
  ],
  "presets": [{"name": "System steps"}]
}
{% endschema %}
