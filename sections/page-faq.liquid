<section class="page-hero"><div class="sh-container"><div class="sh-eyebrow">{{ section.settings.eyebrow }}</div><h1 class="sh-h1">{{ section.settings.heading }}</h1><p class="sh-body">{{ section.settings.body }}</p></div></section>
<section class="sh-section"><div class="sh-container accordion">
  {% for block in section.blocks %}
    {% if block.type == 'faq_group' %}
      <h2 class="sh-h2" style="{% unless forloop.first %}margin-top:50px;{% endunless %}" {{ block.shopify_attributes }}>{{ block.settings.title }}</h2>
    {% elsif block.type == 'faq_item' %}
      <details {{ block.shopify_attributes }}><summary>{{ block.settings.question }}</summary><div class="content">{{ block.settings.answer }}</div></details>
    {% endif %}
  {% endfor %}
</div></section>
{% schema %}
{
  "name": "Page - FAQ",
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "FAQ"},
    {"type": "textarea", "id": "heading", "label": "Heading", "default": "How to use the Shadeless 3-Step Serum System"},
    {"type": "textarea", "id": "body", "label": "Body text", "default": "Answers about routine order, skin types, Peptisinergix™, ingredients, and orders."}
  ],
  "blocks": [
    {
      "type": "faq_group",
      "name": "Group heading",
      "settings": [
        {"type": "text", "id": "title", "label": "Group title"}
      ]
    },
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        {"type": "text", "id": "question", "label": "Question"},
        {"type": "textarea", "id": "answer", "label": "Answer"}
      ]
    }
  ],
  "presets": [{"name": "Page - FAQ"}]
}
{% endschema %}
