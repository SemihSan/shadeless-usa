<section class="page-hero"><div class="sh-container"><div class="sh-eyebrow">{{ section.settings.eyebrow }}</div><h1 class="sh-h1">{{ section.settings.heading }}</h1><p class="sh-body">{{ section.settings.body }}</p></div></section>
<section class="sh-section"><div class="sh-container"><div class="sh-grid sh-grid-3"><div class="sh-card">{{ section.settings.card1 }}</div><div class="sh-card">{{ section.settings.card2 }}</div><div class="sh-card">{{ section.settings.card3 }}</div><div class="sh-card">{{ section.settings.card4 }}</div><div class="sh-card">{{ section.settings.card5 }}</div><div class="sh-card">{{ section.settings.card6 }}</div></div></div></section>
<section class="sh-section"><div class="sh-container"><h2 class="sh-h2">{{ section.settings.policy_heading }}</h2><p class="sh-body">{{ section.settings.policy_body }}</p><p class="sh-small">{{ section.settings.policy_disclaimer }}</p></div></section>
{% schema %}
{
  "name": "Page - Results",
  "settings": [
    {"type": "header", "content": "Hero"},
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Results"},
    {"type": "textarea", "id": "heading", "label": "Heading", "default": "Results, defined carefully."},
    {"type": "textarea", "id": "body", "label": "Body text", "default": "At Shadeless, results mean cosmetic improvements in how skin looks and feels: tone, texture, clarity, smoothness, and visible finish."},
    {"type": "header", "content": "Result cards"},
    {"type": "text", "id": "card1", "label": "Card 1", "default": "Smoother-looking texture"},
    {"type": "text", "id": "card2", "label": "Card 2", "default": "More even-looking tone"},
    {"type": "text", "id": "card3", "label": "Card 3", "default": "Less dull-looking complexion"},
    {"type": "text", "id": "card4", "label": "Card 4", "default": "Cleaner-looking clarity"},
    {"type": "text", "id": "card5", "label": "Card 5", "default": "More refined-looking finish"},
    {"type": "text", "id": "card6", "label": "Card 6", "default": "More polished bare-skin appearance"},
    {"type": "header", "content": "Policy section"},
    {"type": "text", "id": "policy_heading", "label": "Heading", "default": "Before / after policy"},
    {"type": "textarea", "id": "policy_body", "label": "Body text", "default": "Images will only be shown with written consent, consistent lighting, disclosed timing, disclosed usage, no filters, and no guaranteed-results implication."},
    {"type": "text", "id": "policy_disclaimer", "label": "Disclaimer", "default": "Individual results may vary."}
  ],
  "presets": [{"name": "Page - Results"}]
}
{% endschema %}
