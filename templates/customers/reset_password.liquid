<section class="page-hero"><div class="sh-container"><div class="sh-eyebrow">Account</div><h1 class="sh-h1">Reset your password</h1></div></section>
<section class="sh-section"><div class="sh-container" style="max-width:520px;">
  {% form 'reset_customer_password', class: 'contact-form' %}
    <input type="password" name="customer[password]" placeholder="New password" required>
    <input type="password" name="customer[password_confirmation]" placeholder="Confirm password" required>
    <button class="sh-button sh-button--red" type="submit">Reset Password</button>
    {% if form.errors %}<div class="sh-small">{{ form.errors | default_errors }}</div>{% endif %}
  {% endform %}
</div></section>
