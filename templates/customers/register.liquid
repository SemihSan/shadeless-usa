<section class="page-hero"><div class="sh-container"><div class="sh-eyebrow">Account</div><h1 class="sh-h1">Create account</h1></div></section>
<section class="sh-section"><div class="sh-container" style="max-width:520px;">
  {% form 'create_customer', class: 'contact-form' %}
    <input type="text" name="customer[first_name]" placeholder="First name">
    <input type="text" name="customer[last_name]" placeholder="Last name">
    <input type="email" name="customer[email]" placeholder="Email" required>
    <input type="password" name="customer[password]" placeholder="Password" required>
    <button class="sh-button sh-button--red" type="submit">Create Account</button>
    {% if form.errors %}<div class="sh-small">{{ form.errors | default_errors }}</div>{% endif %}
  {% endform %}
  <p class="sh-small" style="margin-top:18px;">Already have an account? <a href="/account/login">Log in</a>.</p>
</div></section>
