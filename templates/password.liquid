<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>{{ shop.name }}</title>
    {{ content_for_header }}
    {{ 'theme.css' | asset_url | stylesheet_tag }}
  </head>
  <body class="template-password">
    <main class="page-hero">
      <div class="sh-container sh-center">
        <a class="brand-logo" href="{{ routes.root_url }}">SHADELESS</a>
        <h1 class="sh-h1" style="margin-top:30px;">Coming soon.</h1>
        <p class="sh-body">Shadeless biotech skincare — Prepare. Optimize. Enhance.</p>

        {% form 'storefront_password', class: 'email-form' %}
          <input type="password" name="password" placeholder="Enter store password" required>
          <button class="sh-button sh-button--red" type="submit">Enter</button>
          {% if form.errors %}<div class="sh-small">{{ form.errors | default_errors }}</div>{% endif %}
        {% endform %}

        <div style="margin-top:36px;">
          <h2 class="sh-h3">Get notified when we launch</h2>
          {% form 'customer', class: 'email-form' %}
            <input type="hidden" name="contact[tags]" value="prospect, password-page">
            <input type="email" name="contact[email]" placeholder="Email" required>
            <button class="sh-button" type="submit">Notify Me</button>
            {% if form.posted_successfully? %}<div class="newsletter-success">Thank you. We'll be in touch.</div>{% endif %}
          {% endform %}
        </div>
      </div>
    </main>
  </body>
</html>
