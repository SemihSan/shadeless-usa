{% doc %}
  @prompt
    product images
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-images-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-product-images__container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
  }

  .ai-product-images__thumbnails-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.thumbnail_gap }}px;
    width: {{ block.settings.thumbnail_width }}px;
    flex-shrink: 0;
  }

  .ai-product-images__thumbnail-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    cursor: pointer;
    border: 2px solid transparent;
    border-radius: {{ block.settings.thumbnail_border_radius }}px;
    overflow: hidden;
    transition: border-color 0.3s ease;
  }

  .ai-product-images__thumbnail-{{ ai_gen_id }}:hover {
    border-color: {{ block.settings.thumbnail_hover_border_color }};
  }

  .ai-product-images__thumbnail-{{ ai_gen_id }}.active {
    border-color: {{ block.settings.thumbnail_active_border_color }};
  }

  .ai-product-images__thumbnail-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-product-images__main-{{ ai_gen_id }} {
    flex-grow: 1;
    position: relative;
  }

  .ai-product-images__main-image-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.main_aspect_ratio }};
    border-radius: {{ block.settings.main_border_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
  }

  .ai-product-images__main-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-product-images__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.background_color }};
    position: relative;
  }

  .ai-product-images__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-product-images__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-product-images__container-{{ ai_gen_id }} {
      flex-direction: column-reverse;
    }

    .ai-product-images__thumbnails-{{ ai_gen_id }} {
      flex-direction: row;
      width: 100%;
      overflow-x: auto;
    }

    .ai-product-images__thumbnail-{{ ai_gen_id }} {
      width: {{ block.settings.thumbnail_width }}px;
      flex-shrink: 0;
    }
  }
{% endstyle %}

<product-images-{{ ai_gen_id }} class="ai-product-images-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-images__container-{{ ai_gen_id }}">
    {% if block.settings.show_thumbnails and product.images.size > 1 %}
      <div class="ai-product-images__thumbnails-{{ ai_gen_id }}">
        {% for image in product.images limit: block.settings.max_thumbnails %}
          <button
            class="ai-product-images__thumbnail-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
            data-image-index="{{ forloop.index0 }}"
            aria-label="View image {{ forloop.index }}"
          >
            <img
              src="{{ image | image_url: width: 200 }}"
              alt="{{ image.alt | escape }}"
              width="200"
              height="200"
              loading="lazy"
            >
          </button>
        {% endfor %}
      </div>
    {% endif %}

    <div class="ai-product-images__main-{{ ai_gen_id }}">
      <div class="ai-product-images__main-image-{{ ai_gen_id }}">
        {% if product.featured_image %}
          <img
            src="{{ product.featured_image | image_url: width: 1200 }}"
            alt="{{ product.featured_image.alt | escape }}"
            width="{{ product.featured_image.width }}"
            height="{{ product.featured_image.height }}"
            loading="eager"
            data-main-image
          >
        {% else %}
          <div class="ai-product-images__placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
            <div class="ai-product-images__empty-state-{{ ai_gen_id }}">
              Next, add product images
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</product-images-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductImages{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.mainImage = this.querySelector('[data-main-image]');
        this.thumbnails = this.querySelectorAll('.ai-product-images__thumbnail-{{ ai_gen_id }}');
        this.productImages = {{ product.images | json }};
        
        if (this.mainImage && this.thumbnails.length > 0) {
          this.setupEventListeners();
        }
      }

      setupEventListeners() {
        this.thumbnails.forEach((thumbnail) => {
          thumbnail.addEventListener('click', (e) => {
            const imageIndex = parseInt(thumbnail.dataset.imageIndex);
            this.switchImage(imageIndex);
            this.setActiveThumbnail(thumbnail);
          });
        });
      }

      switchImage(index) {
        if (this.productImages[index]) {
          const image = this.productImages[index];
          this.mainImage.src = image.src.replace(/\.(jpg|jpeg|png|gif|webp)/, '_1200x.$1');
          this.mainImage.alt = image.alt || '';
        }
      }

      setActiveThumbnail(activeThumbnail) {
        this.thumbnails.forEach((thumb) => {
          thumb.classList.remove('active');
        });
        activeThumbnail.classList.add('active');
      }
    }

    customElements.define('product-images-{{ ai_gen_id }}', ProductImages{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Product images",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "select",
      "id": "main_aspect_ratio",
      "label": "Main image aspect ratio",
      "options": [
        {
          "value": "1",
          "label": "Square (1:1)"
        },
        {
          "value": "0.75",
          "label": "Portrait (3:4)"
        },
        {
          "value": "1.33",
          "label": "Landscape (4:3)"
        },
        {
          "value": "auto",
          "label": "Natural"
        }
      ],
      "default": "1"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between thumbnails and main",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Thumbnails"
    },
    {
      "type": "checkbox",
      "id": "show_thumbnails",
      "label": "Show thumbnails",
      "default": true
    },
    {
      "type": "range",
      "id": "thumbnail_width",
      "label": "Thumbnail width",
      "min": 40,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "thumbnail_gap",
      "label": "Gap between thumbnails",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "max_thumbnails",
      "label": "Maximum thumbnails",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 6
    },
    {
      "type": "range",
      "id": "thumbnail_border_radius",
      "label": "Thumbnail border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "color",
      "id": "thumbnail_hover_border_color",
      "label": "Hover border color",
      "default": "#cccccc"
    },
    {
      "type": "color",
      "id": "thumbnail_active_border_color",
      "label": "Active border color",
      "default": "#9E1717"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "main_border_radius",
      "label": "Main image border radius",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 8
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f4f4f4"
    }
  ],
  "presets": [
    {
      "name": "Product images"
    }
  ]
}
{% endschema %}
